{
  "version": 2,
  "public": true,
  "buildCommand": "exit 0",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/claude-dashboard.html" },
    { "source": "/tracker", "destination": "/manual-tracker.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "max-age=60, s-maxage=60" },
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    }
  ]
}
